{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vasak Terminal",
  "version": "0.1.0",
  "identifier": "ar.net.vasak.vasak-terminal",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vasak Terminal",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "deb",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      },
      "deb": {
        "depends": [
          "vasak-desktop-settings",
          "libcairo2",
          "desktop-file-utils",
          "libgdk-pixbuf-2.0-0",
          "libglib2.0-0t64",
          "libgtk-3-0t64",
          "hicolor-icon-theme",
          "libsoup2.4-1",
          "libsoup-3.0-0",
          "libpango-1.0-0",
          "libwebkit2gtk-4.1-0"
        ],
        "files": {}
      }
    },
    "icon": [
      "icons/logo.png"
    ]
  }
}